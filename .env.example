OPENAI_API_KEY=sk-...
# Web search uses DuckDuckGo (free, no key needed).
# Tavily is optional fallback — set this only if you want it.
# TAVILY_API_KEY=tvly-...
APP_PORT=8000

# Database (Turso) — leave empty for local SQLite
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Vector search (Qdrant Cloud) — optional, gracefully skipped if unavailable
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=

# Authentication
JWT_SECRET=change-this-to-a-random-string

# Unpaywall (for open access papers)
UNPAYWALL_EMAIL=your@email.com
