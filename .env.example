# ──────────────────────────────────────────────────────────────
#  LLM Provider (required)
# ──────────────────────────────────────────────────────────────
# Used for all agents and for generating embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...


# ──────────────────────────────────────────────────────────────
#  Web Search (optional)
# ──────────────────────────────────────────────────────────────
# Primary search uses DuckDuckGo (free, no key needed — via `ddgs` package).
# Tavily is an optional paid fallback used only if DuckDuckGo fails.
# TAVILY_API_KEY=tvly-...


# ──────────────────────────────────────────────────────────────
#  Server
# ──────────────────────────────────────────────────────────────
APP_PORT=8000


# ──────────────────────────────────────────────────────────────
#  Database — Turso (libSQL)
# ──────────────────────────────────────────────────────────────
# Leave both empty to use local SQLite at ./data/deep_research.db
# For production, create a free DB at https://turso.tech:
#   turso db create deep-research
#   turso db tokens create deep-research
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Override local SQLite path (only used when TURSO_* is not set)
# LOCAL_DB_PATH=data/deep_research.db


# ──────────────────────────────────────────────────────────────
#  Vector Search — Qdrant Cloud
# ──────────────────────────────────────────────────────────────
# Optional — pipeline gracefully skips memory features if unavailable.
# Sign up at https://cloud.qdrant.io for a free tier cluster.
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=


# ──────────────────────────────────────────────────────────────
#  Authentication
# ──────────────────────────────────────────────────────────────
# Generate a strong random secret for production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-this-to-a-random-string


# ──────────────────────────────────────────────────────────────
#  Academic Sources (optional)
# ──────────────────────────────────────────────────────────────
# Unpaywall requires an email for the free API (100K calls/day).
# Used when resolving DOIs to legal open-access PDF versions.
UNPAYWALL_EMAIL=your@email.com


# ──────────────────────────────────────────────────────────────
#  Observability (optional)
# ──────────────────────────────────────────────────────────────
# Uncomment to enable OpenTelemetry tracing via AgentScope.
# Phoenix (local):  http://localhost:6006/v1/traces
# Langfuse (cloud): https://cloud.langfuse.com
# TRACING_URL=